{
  "name": "agent",
  "version": "1.0.11",
  "main": "dist/main.js",
  "description": "NetCafe Agent application",
  "author": "Muhammed Ajmal Bin Ashraf <ajmalmohammed13166@gmail.com>",
  "homepage": "https://github.com/MuhammedAjmalBinAshraf/NetCafe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MuhammedAjmalBinAshraf/NetCafe.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "tsc",
    "build:win": "tsc && electron-builder --win -p never",
    "build:linux": "tsc && electron-builder --linux -p never",
    "build:win:ci": "tsc && electron-builder --win -p always",
    "build:linux:ci": "tsc && electron-builder --linux -p always"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.12.7"
  },
  "build": {
    "appId": "com.netcafe.agent",
    "productName": "NetCafe Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "include": "installer.nsh"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "MuhammedAjmalBinAshraf",
      "repo": "NetCafe"
    }
  }
}
