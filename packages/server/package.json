{
  "name": "server",
  "private": true,
  "version": "1.1.24",







  "main": "dist-electron/main.js",
  "type": "module",
  "description": "NetCafe Server application",
  "author": "Muhammed Ajmal Bin Ashraf <ajmalmohammed13166@gmail.com>",
  "homepage": "https://github.com/MuhammedAjmalBinAshraf/NetCafe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MuhammedAjmalBinAshraf/NetCafe.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:win": "tsc -b && vite build && electron-builder --win -p never",
    "build:linux": "tsc -b && vite build && electron-builder --linux -p never",
    "build:win:ci": "tsc -b && vite build && electron-builder --win -p always",
    "build:linux:ci": "tsc -b && vite build && electron-builder --linux -p always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.1.8",
    "express": "^4.21.2",
    "lucide-react": "^0.474.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.0.1",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.netcafe.server",
    "productName": "NetCafe Server",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "requestedExecutionLevel": "requireAdministrator",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "MuhammedAjmalBinAshraf",
      "repo": "NetCafe",
      "channel": "latest-server"
    }
  }
}
